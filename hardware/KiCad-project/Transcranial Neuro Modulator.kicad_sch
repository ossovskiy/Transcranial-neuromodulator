	(text "2) MCU development board\n"
		(exclude_from_sim no)
		(at 82.296 92.71 0)
		(effects
			(font
				(size 1.524 1.524)
				(thickness 0.508)
				(bold yes)
			)
		)
		(uuid "0cfadb27-9c6d-4e0d-89ac-3c6f732782b7")
	)
	(text "Remarks:\n\nUse high accuracy resistors for op-amps!!\n\nFor all the modules in the schematic unused pins are not shown\nIn case of experimenting with frequencies > 4hz the low-pass Fc must be adjusted\n\nThe STM32 used in this project has a built-in reference voltage buffer, so the use of\nthe external ADA4528 for section 3 of this schematic is not necessary. The pots\ncan be connected to the \"ADC Vref out\" pin directly.\n\nThe \"Boost 8 click\" should be modified as follows (refer to the LT1946 datasheet):\n1. For the positive supply: R2 - 18k, R1 - 470k\n2. For the negative supply: R2 - 20k, R1 - 510k\n\nOn the MCU board:\n1. SB8 must be shorted\n2. SB20 must be shorted\n3. SB3 must be open\n4. SB43 must be open\n5. SB40 must be shorted\n6. SB41 must be shorted\n7. SB39 must be shorted\n8. SB42 must be open\n9. SB50 must be open"
		(exclude_from_sim no)
		(at 20.828 240.792 0)
		(effects
			(font
				(size 1.778 1.778)
				(thickness 0.1588)
			)
			(justify left)
		)
		(uuid "17f4c6c8-5209-42af-80e6-9682d885d821")
	)
	(text "1) 5V to +33.5v/-33.5v converter"
		(exclude_from_sim no)
		(at 118.872 37.846 0)
		(effects
			(font
				(size 1.524 1.524)
				(thickness 0.4064)
				(bold yes)
			)
		)
		(uuid "4d814d7c-c4a7-4aed-88ef-3031f2a43a92")
	)
	(text "6) 3rd order low-pass filter (Fc == 25hz)"
